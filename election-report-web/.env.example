# Never commit a real service key.
DATA_GO_KR_SERVICE_KEY=

# Official NEC/public-data API base URLs.
NEC_COMMON_CODE_BASE_URL=https://apis.data.go.kr/9760000/CommonCodeService
NEC_CANDIDATE_BASE_URL=https://apis.data.go.kr/9760000/PofelcddInfoInqireService
NEC_PLEDGE_BASE_URL=https://apis.data.go.kr/9760000/ElecPrmsInfoInqireService

# Expected election ID for the 2026 local election. Confirm through CommonCodeService.
NEXT_PUBLIC_DEFAULT_SG_ID=20260603

# Local PostgreSQL defaults. Change passwords for OCI/production.
POSTGRES_USER=election_report
POSTGRES_PASSWORD=election_report_local_password
POSTGRES_DB=election_report
POSTGRES_PORT=5433
DATABASE_URL=postgresql://election_report:election_report_local_password@localhost:5433/election_report?schema=public
